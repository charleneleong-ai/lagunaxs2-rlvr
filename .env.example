# Copy to .env (gitignored) and fill in. Secrets for the probe/eval + model providers.
# Load with: set -a; source .env; set +a    (or `uv run --env-file .env ...`)

# --- Data: private HF datasets (Adaption seed/output) ---
# Also mirror as a Prime global secret named HF_TOKEN for hosted training reads:
#   prime secret create -n HF_TOKEN -v <token>
HF_TOKEN=hf_xxx
HF_USER=chaleong

# --- Local, $0 proxy ---
OLLAMA_API_KEY=ollama                       # Ollama ignores the value; any non-empty string works

# --- Self-served Laguna on an A100 via vLLM (conf/model/laguna_vllm.yaml) ---
LAGUNA_VLLM_URL=http://localhost:8000/v1
VLLM_API_KEY=laguna

# --- Prime-credit-free API proxies (set whichever you hold) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=                         # Gemini via OpenRouter (conf/model/gemini.yaml)

# --- Experiment tracking (optional; wandb is a dep) ---
WANDB_API_KEY=
